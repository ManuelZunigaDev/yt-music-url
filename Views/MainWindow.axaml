<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:MediaDownloader.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
        x:Class="MediaDownloader.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="MediaDownloader"
        TransparencyLevelHint="AcrylicBlur"
        Background="Transparent"
        ExtendClientAreaToDecorationsHint="True"
        WindowStartupLocation="CenterScreen"
        Width="1000" Height="650">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Panel>
        <ExperimentalAcrylicBorder IsHitTestVisible="False">
            <ExperimentalAcrylicBorder.Material>
                <ExperimentalAcrylicMaterial
                    BackgroundSource="Digger"
                    TintColor="#1E1E1E"
                    TintOpacity="1"
                    MaterialOpacity="0.65" />
            </ExperimentalAcrylicBorder.Material>
        </ExperimentalAcrylicBorder>

        <Grid ColumnDefinitions="*, 350" Margin="20,40,20,20">
            <!-- Panel Izquierdo: Controles -->
            <ScrollViewer Grid.Column="0">
                <StackPanel Spacing="20" Margin="0,0,20,0">
                    <TextBlock Text="Descargador de Medios" FontSize="28" FontWeight="Bold" Foreground="#0078D4"/>
                    
                    <!-- URL -->
                    <StackPanel Spacing="8">
                        <TextBlock Text="URL del Video" FontWeight="SemiBold"/>
                        <Grid ColumnDefinitions="*, Auto">
                            <TextBox Text="{Binding Url}" Watermark="Pegue la URL aquí..." 
                                     CornerRadius="4" Height="36"/>
                            <Button Grid.Column="1" Content="Obtener info" 
                                    Command="{Binding GetInfoCommand}"
                                    Width="120" Height="36" Margin="8,0,0,0"
                                    Background="#0078D4" Foreground="White"/>
                        </Grid>
                    </StackPanel>

                    <!-- Info del Medio -->
                    <Border IsVisible="{Binding MediaInfo, Converter={x:Static ObjectConverters.IsNotNull}}"
                            Background="#2D2D2D" CornerRadius="8" Padding="15">
                        <StackPanel Spacing="5">
                            <TextBlock Text="{Binding MediaInfo.Title}" FontWeight="Bold" TextWrapping="Wrap" FontSize="16"/>
                            <TextBlock Text="{Binding MediaInfo.Duration, StringFormat='Duración: {0}'}" Foreground="#AAAAAA"/>
                        </StackPanel>
                    </Border>

                    <!-- Formato y Recorte -->
                    <Grid ColumnDefinitions="*, *">
                        <StackPanel Spacing="8" Grid.Column="0">
                            <TextBlock Text="Formato de Salida" FontWeight="SemiBold"/>
                            <StackPanel Orientation="Horizontal" Spacing="20">
                                <RadioButton Content="MP4 (Video)" IsChecked="{Binding Format, Converter={StaticResource ObjectConverters.Equal}, ConverterParameter='MP4'}"/>
                                <RadioButton Content="MP3 (Audio)" IsChecked="{Binding Format, Converter={StaticResource ObjectConverters.Equal}, ConverterParameter='MP3'}"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Spacing="8" Grid.Column="1">
                            <TextBlock Text="Recorte (Opcional)" FontWeight="SemiBold"/>
                            <Grid ColumnDefinitions="*, *">
                                <TextBox Text="{Binding StartTime}" Watermark="Inicio (00:00:00)" Margin="0,0,4,0"/>
                                <TextBox Grid.Column="1" Text="{Binding EndTime}" Watermark="Fin (00:00:00)" Margin="4,0,0,0"/>
                            </Grid>
                        </StackPanel>
                    </Grid>

                    <!-- Destino -->
                    <StackPanel Spacing="8">
                        <TextBlock Text="Carpeta de Destino" FontWeight="SemiBold"/>
                        <Grid ColumnDefinitions="*, Auto">
                            <TextBox Text="{Binding OutputFolder}" IsReadOnly="True" CornerRadius="4"/>
                            <Button Grid.Column="1" Content="Cambiar" 
                                    Command="{Binding SelectFolderCommand}"
                                    Width="100" Margin="8,0,0,0"/>
                        </Grid>
                    </StackPanel>

                    <!-- Acciones -->
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button Content="Descargar" Command="{Binding DownloadCommand}" 
                                Width="150" Height="40" Background="#0078D4" Foreground="White" 
                                FontSize="16" FontWeight="Bold"/>
                        <Button Content="Cancelar" Command="{Binding CancelCommand}" 
                                Width="100" Height="40" Background="#444444"/>
                    </StackPanel>

                    <!-- Progreso -->
                    <StackPanel Spacing="8" IsVisible="{Binding IsBusy}">
                        <Grid ColumnDefinitions="*, Auto">
                            <TextBlock Text="{Binding StatusMessage}" Foreground="#0078D4"/>
                            <TextBlock Grid.Column="1" Text="{Binding TotalProgress, StringFormat='{}{0:0}%'}" FontWeight="Bold"/>
                        </Grid>
                        <ProgressBar Value="{Binding TotalProgress}" Minimum="0" Maximum="100" 
                                     Height="6" Foreground="#0078D4" Background="#333333"/>
                    </StackPanel>
                    
                    <!-- Estado Final (No ocupado) -->
                    <TextBlock Text="{Binding StatusMessage}" IsVisible="{Binding !IsBusy}" Foreground="#AAAAAA" FontStyle="Italic"/>
                </StackPanel>
            </ScrollViewer>

            <!-- Panel Derecho: Historial -->
            <Border Grid.Column="1" Background="#252525" CornerRadius="12" Padding="15">
                <Grid RowDefinitions="Auto, *">
                    <TextBlock Text="Historial de Descargas" FontWeight="Bold" Margin="0,0,0,15" FontSize="18"/>
                    <ListBox Grid.Row="1" ItemsSource="{Binding History}" Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#2D2D2D" Margin="0,0,0,8" Padding="10" CornerRadius="6">
                                    <Grid ColumnDefinitions="*, Auto">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Status}" FontSize="12" Foreground="#0078D4"/>
                                            <TextBlock Text="{Binding Date, StringFormat='{}{0:G}'}" FontSize="11" Foreground="#888888"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="{Binding Progress, StringFormat='{}{0:0}%'}" 
                                                   VerticalAlignment="Center" FontWeight="Bold" IsVisible="{Binding Progress, Converter={StaticResource ObjectConverters.NotEqual}, ConverterParameter=0}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>
    </Panel>
</Window>
