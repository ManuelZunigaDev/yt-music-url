<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:MediaDownloader.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:h="using:MediaDownloader.Helpers"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
        x:Class="MediaDownloader.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="XDisk - Professional Media Downloader"
        TransparencyLevelHint="AcrylicBlur"
        Background="Transparent"
        ExtendClientAreaToDecorationsHint="True"
        WindowStartupLocation="CenterScreen"
        Width="1200" Height="800">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Panel>
        <!-- Background Layer -->
        <ExperimentalAcrylicBorder IsHitTestVisible="False">
            <ExperimentalAcrylicBorder.Material>
                <ExperimentalAcrylicMaterial
                    BackgroundSource="Digger"
                    TintColor="#0A0A0A"
                    TintOpacity="1"
                    MaterialOpacity="0.85" />
            </ExperimentalAcrylicBorder.Material>
        </ExperimentalAcrylicBorder>

        <!-- Main Layout -->
        <Grid ColumnDefinitions="280, *, 350">
            
            <!-- Left Sidebar: Brand & Navigation -->
            <Border Grid.Column="0" Background="#0DFFFFFF" BorderBrush="#1AFFFFFF" BorderThickness="0,0,1,0">
                <Grid RowDefinitions="Auto, *, Auto" Margin="30,50,30,30">
                    <!-- Brand Section -->
                    <StackPanel Grid.Row="0" Spacing="20" HorizontalAlignment="Center">
                        <Border Width="100" Height="100" CornerRadius="50" ClipToBounds="True" Background="#1AFFFFFF">
                            <Image Source="avares://MediaDownloader/Assets/logo.png" Stretch="UniformToFill"/>
                        </Border>
                        <TextBlock Text="XDISK" FontSize="26" FontWeight="Black" LetterSpacing="4" HorizontalAlignment="Center"/>
                        <Border Height="2" Width="40" Background="#0078D4" HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- Navigation Links -->
                    <StackPanel Grid.Row="1" Spacing="10" Margin="0,50,0,0">
                        <ListBox Background="Transparent" BorderThickness="0" SelectedIndex="0">
                            <ListBox.Styles>
                                <Style Selector="ListBoxItem">
                                    <Setter Property="Padding" Value="15,12"/>
                                    <Setter Property="CornerRadius" Value="12"/>
                                    <Setter Property="Margin" Value="0,2"/>
                                </Style>
                            </ListBox.Styles>
                            
                            <ListBoxItem>
                                <StackPanel Orientation="Horizontal" Spacing="15">
                                    <Path Data="M10,20V14H14V20H19V12H22L12,3L2,12H5V20H10Z" Fill="#0078D4" Width="18" Height="18" Stretch="Uniform"/>
                                    <TextBlock Text="Descargador" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                </StackPanel>
                            </ListBoxItem>
                            
                            <ListBoxItem Opacity="0.5">
                                <StackPanel Orientation="Horizontal" Spacing="15">
                                    <Path Data="M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.97 19.05,5.05L16.56,6.05C16.04,5.66 15.47,5.34 14.86,5.12L14.47,2.5C14.43,2.25 14.22,2.07 13.97,2.07H9.97C9.72,2.07 9.5,2.25 9.47,2.5L9.07,5.12C8.47,5.34 7.9,5.66 7.37,6.05L4.88,5.05C4.66,4.97 4.39,5.05 4.27,5.27L2.27,8.73C2.15,8.95 2.2,9.22 2.39,9.37L4.5,11C4.46,11.34 4.43,11.67 4.43,12C4.43,12.33 4.46,12.65 4.5,12.97L2.39,14.63C2.2,14.78 2.15,15.05 2.27,15.27L4.27,18.73C4.39,18.95 4.66,19.03 4.88,18.95L7.37,17.95C7.9,18.34 8.47,18.66 9.07,18.88L9.47,21.5C9.5,21.75 9.72,21.93 9.97,21.93H13.97C14.22,21.93 14.43,21.75 14.47,21.5L14.86,18.88C15.47,18.66 16.04,18.34 16.56,17.95L19.05,18.95C19.27,19.03 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z" Fill="White" Width="18" Height="18" Stretch="Uniform"/>
                                    <TextBlock Text="Ajustes" VerticalAlignment="Center"/>
                                </StackPanel>
                            </ListBoxItem>
                        </ListBox>
                    </StackPanel>

                    <!-- Status Footer -->
                    <Border Grid.Row="2" Background="#1AFFFFFF" CornerRadius="12" Padding="15">
                        <StackPanel Spacing="5">
                            <TextBlock Text="ESTADO" FontSize="10" FontWeight="Bold" Opacity="0.5"/>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Ellipse Width="8" Height="8" Fill="#4CAF50"/>
                                <TextBlock Text="Sistema Online" FontSize="12" Foreground="#4CAF50"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Center Column: Core UI -->
            <ScrollViewer Grid.Column="1">
                <StackPanel Spacing="40" Margin="40,60,40,40">
                    <!-- Welcome Header & Idle State Illustration -->
                    <StackPanel Spacing="20" IsVisible="{Binding MediaInfo, Converter={x:Static ObjectConverters.IsNull}}">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Bienvenido a XDisk" FontSize="36" FontWeight="Black"/>
                            <TextBlock Text="Ingresa el enlace de cualquier video o música para comenzar." Opacity="0.6" FontSize="16"/>
                        </StackPanel>
                        
                        <!-- DrawKit Character Illustration -->
                        <Border HorizontalAlignment="Center" Margin="0,0,0,10">
                            <Image Source="avares://MediaDownloader/Assets/welcome_idle.png" 
                                   Height="260" 
                                   Stretch="Uniform"
                                   HorizontalAlignment="Center"/>
                        </Border>
                    </StackPanel>

                    <!-- Header when content is loaded (Smaller) -->
                    <StackPanel Spacing="8" IsVisible="{Binding MediaInfo, Converter={x:Static ObjectConverters.IsNotNull}}">
                        <TextBlock Text="Contenido Detectado" FontSize="24" FontWeight="Black"/>
                    </StackPanel>

                    <!-- Main Input Card -->
                    <Border Background="#0DFFFFFF" BorderBrush="#1AFFFFFF" BorderThickness="1" CornerRadius="24" Padding="30">
                        <StackPanel Spacing="25">
                            <Grid ColumnDefinitions="*, Auto">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="URL DEL CONTENIDO" FontSize="11" FontWeight="Bold" Opacity="0.5" Margin="5,0,0,0"/>
                                    <TextBox Text="{Binding Url}" 
                                             Watermark="Pegue aquí el enlace de YouTube, TikTok, etc..." 
                                             CornerRadius="12" 
                                             Height="54" 
                                             FontSize="16"
                                             VerticalContentAlignment="Center"
                                             Background="#1A000000" 
                                             BorderThickness="1" 
                                             BorderBrush="#33FFFFFF"/>
                                </StackPanel>
                                <Button Grid.Column="1" 
                                        Command="{Binding GetInfoCommand}"
                                        Margin="15,21,0,0" 
                                        Width="160" 
                                        Height="54" 
                                        CornerRadius="12"
                                        Background="#0078D4" 
                                        FontWeight="Bold"
                                        Classes="accent">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <Path Data="M9.5,3A6.5,6.5 0 0,1 16,9.5C16,11.11 15.41,12.59 14.44,13.73L14.71,14H15.5L20.5,19L19,20.5L14,15.5V14.71L13.73,14.44C12.59,15.41 11.11,16 9.5,16A6.5,6.5 0 0,1 3,9.5A6.5,6.5 0 0,1 9.5,3M9.5,5C7,5 5,7 5,9.5C5,12 7,14 9.5,14C12,14 14,12 14,9.5C14,7 12,5 9.5,5Z" Fill="White" Width="18" Height="18" Stretch="Uniform"/>
                                        <TextBlock Text="Analizar URL"/>
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <!-- Settings Row -->
                            <Grid ColumnDefinitions="*, *">
                                <StackPanel Grid.Column="0" Spacing="12" Margin="0,0,15,0">
                                    <TextBlock Text="FORMATO" FontSize="11" FontWeight="Bold" Opacity="0.5"/>
                                    <StackPanel Orientation="Horizontal" Spacing="20">
                                        <RadioButton Content="MP4 Video" FontWeight="SemiBold" IsChecked="{Binding Format, Converter={StaticResource ComparisonConverter}, ConverterParameter='MP4'}"/>
                                        <RadioButton Content="MP3 Audio" FontWeight="SemiBold" IsChecked="{Binding Format, Converter={StaticResource ComparisonConverter}, ConverterParameter='MP3'}"/>
                                    </StackPanel>
                                </StackPanel>
                                
                                <StackPanel Grid.Column="1" Spacing="12">
                                    <TextBlock Text="RECORTE (OPCIONAL)" FontSize="11" FontWeight="Bold" Opacity="0.5"/>
                                    <Grid ColumnDefinitions="*, *">
                                        <TextBox Text="{Binding StartTime}" Watermark="00:00:00" Margin="0,0,8,0" CornerRadius="10" Background="#1A000000"/>
                                        <TextBox Grid.Column="1" Text="{Binding EndTime}" Watermark="Manual" Margin="8,0,0,0" CornerRadius="10" Background="#1A000000"/>
                                    </Grid>
                                </StackPanel>
                            </Grid>

                            <StackPanel Spacing="12">
                                <TextBlock Text="CARPETA DE DESTINO" FontSize="11" FontWeight="Bold" Opacity="0.5"/>
                                <Grid ColumnDefinitions="*, Auto">
                                    <TextBox Text="{Binding OutputFolder}" IsReadOnly="True" CornerRadius="10" Height="45" Background="#1A000000" VerticalContentAlignment="Center"/>
                                    <Button Grid.Column="1" Command="{Binding SelectFolderCommand}" Margin="12,0,0,0" Width="50" Height="45" CornerRadius="10">
                                        <Path Data="M20,6H12L10,4H4A2,2 0 0,0 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V8A2,2 0 0,0 20,6M20,18H4V6H9.17L11.17,8H20V18Z" Fill="White" Width="18" Height="18" Stretch="Uniform"/>
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Selected Media Info -->
                    <Border IsVisible="{Binding MediaInfo, Converter={x:Static ObjectConverters.IsNotNull}}"
                            Background="#0078D4" CornerRadius="24" Padding="1">
                        <Border Background="#1A1A1A" CornerRadius="23" Padding="25">
                            <Grid ColumnDefinitions="Auto, *">
                                <Border Width="110" Height="110" Background="#2A2A2A" CornerRadius="16" Margin="0,0,20,0" BorderBrush="#33FFFFFF" BorderThickness="1">
                                    <Path Data="M18,3H6A3,3 0 0,0 3,6V18A3,3 0 0,0 6,21H18A3,3 0 0,0 21,18V6A3,3 0 0,0 18,3M18,19H6A1,1 0 0,1 5,18V6A1,1 0 0,1 6,5H18A1,1 0 0,1 19,6V18A1,1 0 0,1 18,19M8,12L14,16V8L8,12Z" Fill="#0078D4" Width="50" Height="50" Stretch="Uniform"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="8">
                                    <TextBlock Text="{Binding MediaInfo.Title}" FontSize="22" FontWeight="Bold" TextWrapping="Wrap"/>
                                    <Border Background="#33FFFFFF" CornerRadius="8" Padding="10,5" HorizontalAlignment="Left">
                                        <TextBlock Text="{Binding MediaInfo.Duration, StringFormat='Duración: {0}'}" FontSize="13" FontWeight="SemiBold"/>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Border>

                    <!-- Actions -->
                    <StackPanel Spacing="25">
                        <Button Command="{Binding DownloadCommand}" 
                                Foreground="White"
                                HorizontalAlignment="Stretch" 
                                Height="70" 
                                CornerRadius="16"
                                FontSize="20" FontWeight="Black">
                            <Button.Background>
                                <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
                                    <GradientStop Offset="0" Color="#0078D4"/>
                                    <GradientStop Offset="1" Color="#00C2FF"/>
                                </LinearGradientBrush>
                            </Button.Background>
                            <StackPanel Orientation="Horizontal" Spacing="15">
                                <Path Data="M5,20H19V18H5V20M19,9H15V3H9V9H5L12,16L19,9Z" Fill="White" Width="24" Height="24" Stretch="Uniform"/>
                                <TextBlock Text="INICIAR DESCARGA" LetterSpacing="2"/>
                            </StackPanel>
                        </Button>

                        <!-- Downloading State with Illustration -->
                        <Border IsVisible="{Binding IsBusy}" Background="#0DFFFFFF" CornerRadius="20" Padding="25">
                            <StackPanel Spacing="20">
                                <Image Source="avares://MediaDownloader/Assets/downloading_progress.png" 
                                       Height="160" 
                                       Stretch="Uniform"
                                       HorizontalAlignment="Center"/>
                                <Grid ColumnDefinitions="*, Auto">
                                    <TextBlock Text="{Binding StatusMessage}" FontSize="14" Foreground="#00C2FF" FontWeight="Bold" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding TotalProgress, StringFormat='{}{0:0}%'}" FontWeight="Black" FontSize="24" Foreground="#0078D4"/>
                                </Grid>
                                <ProgressBar Value="{Binding TotalProgress}" Minimum="0" Maximum="100" 
                                             Height="14" CornerRadius="7" Foreground="#0078D4" Background="#1AFFFFFF"/>
                                <TextBlock Text="Descargando tu contenido, por favor espera..." 
                                           HorizontalAlignment="Center" Opacity="0.4" FontSize="13" FontStyle="Italic"/>
                            </StackPanel>
                        </Border>

                        <!-- Download Complete Illustration -->
                        <Border IsVisible="{Binding IsDownloadComplete}" Background="#0D4CAF50" CornerRadius="20" Padding="25" BorderBrush="#334CAF50" BorderThickness="1">
                            <StackPanel Spacing="15" HorizontalAlignment="Center">
                                <Image Source="avares://MediaDownloader/Assets/download_complete.png" 
                                       Height="180" 
                                       Stretch="Uniform"
                                       HorizontalAlignment="Center"/>
                                <TextBlock Text="¡Descarga completada!" FontSize="22" FontWeight="Black" Foreground="#4CAF50" HorizontalAlignment="Center"/>
                                <TextBlock Text="Tu archivo ha sido guardado exitosamente." 
                                           HorizontalAlignment="Center" Opacity="0.6" FontSize="14"/>
                            </StackPanel>
                        </Border>

                        <!-- Idle status message (no download in progress, no completion) -->
                        <TextBlock Text="{Binding StatusMessage}" IsVisible="{Binding !IsBusy}" 
                                   HorizontalAlignment="Center" Opacity="0.4" FontSize="14" FontWeight="Medium">
                            <TextBlock.IsVisible>
                                <MultiBinding Converter="{x:Static BoolConverters.And}">
                                    <Binding Path="!IsBusy"/>
                                    <Binding Path="!IsDownloadComplete"/>
                                </MultiBinding>
                            </TextBlock.IsVisible>
                        </TextBlock>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- Right Column: Activity History -->
            <Border Grid.Column="2" Background="#0DFFFFFF" BorderBrush="#1AFFFFFF" BorderThickness="1,0,0,0" Padding="30,50,30,30">
                <Grid RowDefinitions="Auto, *">
                    <StackPanel Spacing="5" Margin="0,0,0,30">
                        <TextBlock Text="Actividad Reciente" FontSize="20" FontWeight="Bold"/>
                        <TextBlock Text="Tus últimas descargas" FontSize="13" Opacity="0.5"/>
                    </StackPanel>

                    <!-- Empty History State -->
                    <StackPanel Grid.Row="1" VerticalAlignment="Center" Spacing="15" 
                                IsVisible="{Binding !History.Count}">
                        <Image Source="avares://MediaDownloader/Assets/empty_history.png" 
                               Height="150" 
                               Stretch="Uniform"
                               HorizontalAlignment="Center"
                               Opacity="0.8"/>
                        <TextBlock Text="Sin actividad aún" FontSize="16" FontWeight="Bold" 
                                   HorizontalAlignment="Center" Opacity="0.5"/>
                        <TextBlock Text="Tus descargas aparecerán aquí" FontSize="12" 
                                   HorizontalAlignment="Center" Opacity="0.3"/>
                    </StackPanel>

                    <ListBox Grid.Row="1" ItemsSource="{Binding History}" Background="Transparent" BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#1AFFFFFF" CornerRadius="16" Padding="18" Margin="0,0,0,15" BorderBrush="#1AFFFFFF" BorderThickness="1">
                                    <StackPanel Spacing="12">
                                        <Grid ColumnDefinitions="*, Auto">
                                            <TextBlock Text="{Binding Name}" FontWeight="Bold" TextTrimming="CharacterEllipsis" FontSize="14"/>
                                            <Border Grid.Column="1" Width="22" Height="22" CornerRadius="11" Background="#4CAF50" 
                                                    IsVisible="{Binding Status, Converter={StaticResource ComparisonConverter}, ConverterParameter='Completado'}">
                                                <Path Data="M21,7L9,19L3.5,13.5L4.91,12.09L9,16.17L19.59,5.59L21,7Z" 
                                                      Fill="White" Width="12" Height="12" Stretch="Uniform"/>
                                            </Border>
                                        </Grid>
                                        
                                        <Grid ColumnDefinitions="*, Auto">
                                            <StackPanel Spacing="3">
                                                <TextBlock Text="{Binding Status}" FontSize="12" FontWeight="SemiBold" Opacity="0.7"/>
                                                <TextBlock Text="{Binding Date, StringFormat='{}{0:f}'}" FontSize="10" Opacity="0.4"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                                <TextBlock Text="{Binding Progress, StringFormat='{}{0:0}%'}" 
                                                           FontWeight="Black" FontSize="16" Foreground="#0078D4"
                                                           IsVisible="{Binding Progress, Converter={StaticResource NotEqualConverter}, ConverterParameter=0}"/>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>
    </Panel>
</Window>

