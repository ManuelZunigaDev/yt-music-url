<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:MediaDownloader.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:h="using:MediaDownloader.Helpers"
        mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="700"
        x:Class="MediaDownloader.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="MediaDownloader Pro"
        TransparencyLevelHint="AcrylicBlur"
        Background="Transparent"
        ExtendClientAreaToDecorationsHint="True"
        WindowStartupLocation="CenterScreen"
        Width="1100" Height="700">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Panel>
        <ExperimentalAcrylicBorder IsHitTestVisible="False">
            <ExperimentalAcrylicBorder.Material>
                <ExperimentalAcrylicMaterial
                    BackgroundSource="Digger"
                    TintColor="#0F0F0F"
                    TintOpacity="1"
                    MaterialOpacity="0.8" />
            </ExperimentalAcrylicBorder.Material>
        </ExperimentalAcrylicBorder>

        <Grid ColumnDefinitions="280, *, 320" Margin="0,30,0,0">
            <!-- Columna 1: Navegación -->
            <StackPanel Grid.Column="0" Spacing="25" Margin="25,40,20,20">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <Path Data="M12,2L4.5,20.29L5.21,21L12,18L18.79,21L19.5,20.29L12,2Z" 
                          Fill="#0078D4" Width="24" Height="24" Stretch="Uniform"/>
                    <TextBlock Text="MediaPro" FontSize="22" FontWeight="Black" LetterSpacing="1" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Spacing="10">
                    <Border Background="#1AFFFFFF" CornerRadius="8" Padding="12,8">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Path Data="M10,20V14H14V20H19V12H22L12,3L2,12H5V20H10Z" Fill="White" Width="16" Height="16" Stretch="Uniform"/>
                            <TextBlock Text="Inicio" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>
                    <Border Background="Transparent" CornerRadius="8" Padding="12,8" Opacity="0.6">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Path Data="M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.97 19.05,5.05L16.56,6.05C16.04,5.66 15.47,5.34 14.86,5.12L14.47,2.5C14.43,2.25 14.22,2.07 13.97,2.07H9.97C9.72,2.07 9.5,2.25 9.47,2.5L9.07,5.12C8.47,5.34 7.9,5.66 7.37,6.05L4.88,5.05C4.66,4.97 4.39,5.05 4.27,5.27L2.27,8.73C2.15,8.95 2.2,9.22 2.39,9.37L4.5,11C4.46,11.34 4.43,11.67 4.43,12C4.43,12.33 4.46,12.65 4.5,12.97L2.39,14.63C2.2,14.78 2.15,15.05 2.27,15.27L4.27,18.73C4.39,18.95 4.66,19.03 4.88,18.95L7.37,17.95C7.9,18.34 8.47,18.66 9.07,18.88L9.47,21.5C9.5,21.75 9.72,21.93 9.97,21.93H13.97C14.22,21.93 14.43,21.75 14.47,21.5L14.86,18.88C15.47,18.66 16.04,18.34 16.56,17.95L19.05,18.95C19.27,19.03 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z" Fill="White" Width="16" Height="16" Stretch="Uniform"/>
                            <TextBlock Text="Configuración" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <Separator Background="#33FFFFFF" Height="1"/>
                
                <StackPanel Spacing="8">
                    <TextBlock Text="ESTADO" FontSize="10" FontWeight="Bold" Opacity="0.5" Margin="5,0,0,5"/>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Ellipse Width="8" Height="8" Fill="#4CAF50"/>
                        <TextBlock Text="Herramientas Listas" FontSize="12" Foreground="#4CAF50"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>

            <!-- Columna 2: Área Principal -->
            <Border Grid.Column="1" Background="#0AFFFFFF" CornerRadius="20,0,0,0" Padding="30">
                <ScrollViewer>
                    <StackPanel Spacing="30">
                        <TextBlock Text="Explorar Medios" FontSize="32" FontWeight="Bold"/>

                        <Border Background="#1AFFFFFF" CornerRadius="15" Padding="20">
                            <StackPanel Spacing="15">
                                <TextBlock Text="URL pública" FontWeight="SemiBold" Opacity="0.8"/>
                                <Grid ColumnDefinitions="*, Auto">
                                    <TextBox Text="{Binding Url}" Watermark="https://..." 
                                             CornerRadius="8" Height="45" FontSize="14"
                                             Background="#222222" BorderThickness="1" BorderBrush="#33FFFFFF"/>
                                    <Button Grid.Column="1" Command="{Binding GetInfoCommand}"
                                            Margin="10,0,0,0" Width="140" Height="45" CornerRadius="8"
                                            Background="#0078D4" FontWeight="Bold">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <Path Data="M9.5,3A6.5,6.5 0 0,1 16,9.5C16,11.11 15.41,12.59 14.44,13.73L14.71,14H15.5L20.5,19L19,20.5L14,15.5V14.71L13.73,14.44C12.59,15.41 11.11,16 9.5,16A6.5,6.5 0 0,1 3,9.5A6.5,6.5 0 0,1 9.5,3M9.5,5C7,5 5,7 5,9.5C5,12 7,14 9.5,14C12,14 14,12 14,9.5C14,7 12,5 9.5,5Z" Fill="White" Width="16" Height="16" Stretch="Uniform"/>
                                            <TextBlock Text="Analizar"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border IsVisible="{Binding MediaInfo, Converter={x:Static ObjectConverters.IsNotNull}}"
                                Background="#0078D4" Opacity="0.9" CornerRadius="15" Padding="2">
                            <Border Background="#1E1E1E" CornerRadius="13" Padding="20">
                                <Grid ColumnDefinitions="Auto, *">
                                    <Border Width="80" Height="80" Background="#333333" CornerRadius="10" Margin="0,0,15,0">
                                        <Path Data="M18,3H6A3,3 0 0,0 3,6V18A3,3 0 0,0 6,21H18A3,3 0 0,0 21,18V6A3,3 0 0,0 18,3M18,19H6A1,1 0 0,1 5,18V6A1,1 0 0,1 6,5H18A1,1 0 0,1 19,6V18A1,1 0 0,1 18,19M8,12L14,16V8L8,12Z" Fill="#0078D4" Width="40" Height="40" Stretch="Uniform"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="5">
                                        <TextBlock Text="{Binding MediaInfo.Title}" FontSize="18" FontWeight="Bold" TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding MediaInfo.Duration, StringFormat='Duración: {0}'}" Opacity="0.7"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Border>

                        <StackPanel Spacing="15">
                            <TextBlock Text="Ajustes" FontSize="20" FontWeight="Bold"/>
                            <Grid ColumnDefinitions="*, *">
                                <StackPanel Grid.Column="0" Spacing="10" Margin="0,0,10,0">
                                    <TextBlock Text="Formato" FontWeight="SemiBold" Opacity="0.8"/>
                                    <StackPanel Orientation="Horizontal" Spacing="15">
                                        <RadioButton Content="MP4" FontSize="14" IsChecked="{Binding Format, Converter={StaticResource ComparisonConverter}, ConverterParameter='MP4'}"/>
                                        <RadioButton Content="MP3" FontSize="14" IsChecked="{Binding Format, Converter={StaticResource ComparisonConverter}, ConverterParameter='MP3'}"/>
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="10">
                                    <TextBlock Text="Recorte" FontWeight="SemiBold" Opacity="0.8"/>
                                    <Grid ColumnDefinitions="*, *">
                                        <TextBox Text="{Binding StartTime}" Watermark="Inicio" Margin="0,0,5,0" CornerRadius="6" Background="#222222"/>
                                        <TextBox Grid.Column="1" Text="{Binding EndTime}" Watermark="Fin" Margin="5,0,0,0" CornerRadius="6" Background="#222222"/>
                                    </Grid>
                                </StackPanel>
                            </Grid>

                            <StackPanel Spacing="10">
                                <TextBlock Text="Destino" FontWeight="SemiBold" Opacity="0.8"/>
                                <Grid ColumnDefinitions="*, Auto">
                                    <TextBox Text="{Binding OutputFolder}" IsReadOnly="True" CornerRadius="6" Background="#222222"/>
                                    <Button Grid.Column="1" Command="{Binding SelectFolderCommand}" Margin="10,0,0,0" Width="45" Height="36">
                                        <Path Data="M20,6H12L10,4H4A2,2 0 0,0 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V8A2,2 0 0,0 20,6M20,18H4V6H9.17L11.17,8H20V18Z" Fill="White" Width="16" Height="16" Stretch="Uniform"/>
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Spacing="15">
                            <Button Command="{Binding DownloadCommand}" Foreground="White"
                                    HorizontalAlignment="Stretch" Height="55" CornerRadius="12"
                                    FontSize="18" FontWeight="ExtraBold">
                                <Button.Background>
                                    <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
                                        <GradientStop Offset="0" Color="#0078D4"/>
                                        <GradientStop Offset="1" Color="#00A2FF"/>
                                    </LinearGradientBrush>
                                </Button.Background>
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <Path Data="M5,20H19V18H5V20M19,9H15V3H9V9H5L12,16L19,9Z" Fill="White" Width="20" Height="20" Stretch="Uniform"/>
                                    <TextBlock Text="DESCARGAR"/>
                                </StackPanel>
                            </Button>

                            <StackPanel Spacing="10" IsVisible="{Binding IsBusy}">
                                <Grid ColumnDefinitions="*, Auto">
                                    <TextBlock Text="{Binding StatusMessage}" FontSize="13" Foreground="#0078D4" FontWeight="Bold"/>
                                    <TextBlock Grid.Column="1" Text="{Binding TotalProgress, StringFormat='{}{0:0}%'}" FontWeight="Black" FontSize="16"/>
                                </Grid>
                                <ProgressBar Value="{Binding TotalProgress}" Minimum="0" Maximum="100" 
                                             Height="8" CornerRadius="4" Foreground="#0078D4" Background="#33FFFFFF"/>
                            </StackPanel>

                            <TextBlock Text="{Binding StatusMessage}" IsVisible="{Binding !IsBusy}" 
                                       HorizontalAlignment="Center" Opacity="0.6" FontSize="13"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Columna 3: Historial -->
            <Border Grid.Column="2" Background="#11FFFFFF" Padding="20">
                <Grid RowDefinitions="Auto, *">
                    <StackPanel Spacing="5" Margin="0,0,0,20">
                        <TextBlock Text="Historial" FontSize="20" FontWeight="Bold"/>
                    </StackPanel>

                    <ListBox Grid.Row="1" ItemsSource="{Binding History}" Background="Transparent" BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#1AFFFFFF" CornerRadius="12" Padding="15" Margin="0,0,0,10">
                                    <StackPanel Spacing="8">
                                        <Grid ColumnDefinitions="*, Auto">
                                            <TextBlock Text="{Binding Name}" FontWeight="Bold" TextTrimming="CharacterEllipsis" FontSize="13"/>
                                            <Path Grid.Column="1" Data="M21,7L9,19L3.5,13.5L4.91,12.09L9,16.17L19.59,5.59L21,7Z" 
                                                  Fill="#4CAF50" Width="14" Height="14" Stretch="Uniform"
                                                  IsVisible="{Binding Status, Converter={StaticResource ComparisonConverter}, ConverterParameter='Completado'}"/>
                                        </Grid>
                                        <Grid ColumnDefinitions="*, Auto">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Status}" FontSize="11" Opacity="0.7"/>
                                                <TextBlock Text="{Binding Date, StringFormat='{}{0:t}'}" FontSize="10" Opacity="0.4"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Text="{Binding Progress, StringFormat='{}{0:0}%'}" 
                                                       VerticalAlignment="Bottom" FontWeight="Bold" FontSize="14" Foreground="#0078D4"
                                                       IsVisible="{Binding Progress, Converter={StaticResource NotEqualConverter}, ConverterParameter=0}"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>
    </Panel>
</Window>
